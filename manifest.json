{
  "manifest_version": 2,
  "name": "X Blocker",
  "version": "1.0.0",
  "description": "Limit X.com (Twitter) usage to 1 minute per hour. Stay focused!",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "webRequest",
    "webRequestBlocking",
    "*://x.com/*",
    "*://twitter.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "web_accessible_resources": [
    "blocked.html",
    "blocked.css",
    "icons/icon-48.png"
  ]
}